# De Vuelta — Environment Variables Template
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase (supabase.com → project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox (account.mapbox.com → tokens)
NEXT_PUBLIC_MAPBOX_TOKEN=

# OneSignal (onesignal.com → settings → keys & IDs)
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Anthropic (console.anthropic.com → API keys)
ANTHROPIC_API_KEY=

# MercadoPago (mercadopago.com.mx → developers → credentials)
# Use sandbox credentials until Phase 8
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
